---
import ThemeToggle from '@/components/ui/ThemeToggle.astro';
import Icon from '@/components/ui/Icon.astro';
import SiteLogo from '@/components/ui/SiteLogo.astro';
import { REPO_SLUG, REPO_URL } from '@/lib/github';

interface Props {
  docsHref?: string;
  blogHref?: string;
  languageHref?: string;
  languageLabel?: string;
  homeHref?: string;
  docsLabel?: string;
  blogLabel?: string;
  hubLabel?: string;
  githubLabel?: string;
  menuLabel?: string;
  closeLabel?: string;
  stars?: string;
}

const {
  docsHref = '/docs/getting-started/',
  blogHref = '/posts/',
  languageHref = '/zh-cn/',
  languageLabel = '中文',
  homeHref = '/',
  docsLabel = 'Docs',
  blogLabel = 'Blog',
  hubLabel = 'Plugins',
  githubLabel = 'GitHub',
  menuLabel = 'Menu',
  closeLabel = 'Close',
  stars,
}: Props = Astro.props;

const hasStars = Boolean(stars);

const navItems = [
  { href: docsHref, label: docsLabel, icon: 'book' as const },
  { href: blogHref, label: blogLabel, icon: 'newspaper' as const },
  { href: 'https://hub.bub.build', label: hubLabel, icon: 'package' as const },
];
---

<header class="sticky top-0 z-50 border-b border-border/60 bg-background/80 backdrop-blur-md w-full" role="banner">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3 md:px-8">
    <!-- Brand -->
    <a class="flex items-center gap-2.5 text-[0.95rem] font-bold tracking-tight text-foreground no-underline" href={homeHref}>
      <SiteLogo alt="Bub" width={32} height={32} class="h-8 w-8" />
      <span>Bub</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-5 text-sm text-muted-foreground md:flex" role="navigation" aria-label="Main navigation">
      {navItems.map((item) => (
        <a
          class="flex items-center gap-1.5 no-underline transition-colors hover:text-foreground"
          href={item.href}
        >
          {item.icon && <Icon name={item.icon} size={14} class="opacity-50" aria-hidden="true" />}
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Right side -->
    <div class="flex items-center gap-2">
      <a
        class="github-nav-button group hidden items-center gap-1.5 border border-border px-3.5 py-1.5 text-sm text-foreground no-underline transition-colors duration-200 hover:bg-secondary md:inline-flex"
        href={REPO_URL}
        target="_blank"
        rel="noreferrer"
        aria-label={`${githubLabel}: ${REPO_SLUG}`}
        title={githubLabel}
      >
        <span class="github-nav-button__icon-wrap" aria-hidden="true">
          <Icon name="github" size={14} class="github-nav-button__github opacity-60" />
          <Icon name="star" size={14} class="github-nav-button__star" fill="currentColor" />
        </span>
        <span>{REPO_SLUG}</span>
        {hasStars && <span class="border-l border-border pl-1.5 text-xs text-muted-foreground">{stars}</span>}
      </a>
      <a
        class="hidden items-center gap-1.5 border border-border px-3.5 py-1.5 text-sm text-foreground no-underline transition-colors hover:bg-secondary md:inline-flex"
        href={languageHref}
      >
        <Icon name="languages" size={14} class="opacity-50" aria-hidden="true" />
        {languageLabel}
      </a>
      <ThemeToggle />

      <!-- Mobile menu -->
      <details class="group md:hidden">
        <summary class="inline-flex h-9 w-9 list-none items-center justify-center border border-border text-foreground marker:content-none">
          <Icon name="menu" size={18} class="group-open:hidden" aria-hidden="true" />
          <Icon name="x" size={18} class="hidden group-open:block" aria-hidden="true" />
          <span class="sr-only group-open:hidden">{menuLabel}</span>
          <span class="sr-only hidden group-open:inline">{closeLabel}</span>
        </summary>
        <nav class="mobile-dropdown absolute left-0 right-0 top-full border-b border-border/60 bg-background/95 backdrop-blur-md p-5" role="navigation" aria-label="Mobile navigation">
          <div class="grid gap-0 text-sm">
            {navItems.map((item) => (
              <a
                class="flex items-center gap-2.5 border-b border-border/50 px-3 py-3 text-foreground no-underline transition-colors hover:bg-secondary"
                href={item.href}
              >
                <Icon name={item.icon} size={15} class="opacity-50" aria-hidden="true" />
                {item.label}
              </a>
            ))}
            <a class="github-nav-button flex items-center gap-2.5 border-b border-border/50 px-3 py-3 text-foreground no-underline transition-colors hover:bg-secondary" href={REPO_URL} target="_blank" rel="noreferrer" aria-label={`${githubLabel}: ${REPO_SLUG}`} title={githubLabel}>
              <span class="github-nav-button__icon-wrap shrink-0" aria-hidden="true">
                <Icon name="github" size={15} class="github-nav-button__github opacity-60" />
                <Icon name="star" size={15} class="github-nav-button__star" fill="currentColor" />
              </span>
              {REPO_SLUG}
              {hasStars && (
                <span class="ml-auto flex items-center gap-1 text-xs text-muted-foreground">
                  <Icon name="star" size={12} fill="currentColor" aria-hidden="true" />
                  {stars}
                </span>
              )}
            </a>
            <a class="flex items-center gap-2.5 px-3 py-3 text-foreground no-underline transition-colors hover:bg-secondary" href={languageHref}>
              <Icon name="languages" size={15} class="opacity-50" aria-hidden="true" />
              {languageLabel}
            </a>
          </div>
        </nav>
      </details>
    </div>
  </div>
</header>

<style>
  .github-nav-button__icon-wrap {
    position: relative;
    display: inline-flex;
    width: 0.875rem;
    height: 0.875rem;
    align-items: center;
    justify-content: center;
  }

  .github-nav-button__icon-wrap > :global(svg) {
    position: absolute;
    inset: 0;
    transition:
      opacity 0.2s ease,
      transform 0.22s ease,
      color 0.2s ease,
      filter 0.25s ease;
  }

  .github-nav-button__star {
    opacity: 0;
    transform: scale(0.72) rotate(-10deg);
    color: var(--site-accent-warm);
    filter: drop-shadow(0 0 0 var(--site-accent-warm-shadow-idle));
  }

  .github-nav-button:hover .github-nav-button__github,
  .mobile-dropdown a:hover .github-nav-button__github {
    opacity: 0;
    transform: scale(0.72) rotate(8deg);
  }

  .github-nav-button:hover .github-nav-button__star,
  .mobile-dropdown a:hover .github-nav-button__star {
    opacity: 1;
    transform: scale(1.05) rotate(0deg);
    filter: drop-shadow(0 0 8px var(--site-accent-warm-shadow));
  }

  .mobile-dropdown {
    animation: mobile-menu-slide-down 0.2s ease-out;
  }

  @keyframes mobile-menu-slide-down {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

---
import Icon from './ui/Icon.astro';
import ThemeToggle from './ThemeToggle.astro';

const {
  docsHref = '/docs/getting-started/',
  blogHref = '/posts/',
  languageHref = '/zh-cn/',
  languageLabel = '中文',
  homeHref = '/',
  docsLabel = 'Docs',
  blogLabel = 'Blog',
  hubLabel = 'Plugins',
  menuLabel = 'Menu',
  closeLabel = 'Close',
} = Astro.props;

const navItems = [
  { href: docsHref, label: docsLabel, icon: 'book' as const },
  { href: blogHref, label: blogLabel, icon: 'newspaper' as const },
  { href: 'https://hub.bub.build', label: hubLabel, icon: 'package' as const },
];

const stars = '99k';
---

<header class="sticky top-0 z-50 border-b border-border bg-background/95 backdrop-blur-sm" role="banner">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3 md:px-8">
    <!-- Brand -->
    <a class="flex items-center gap-2.5 text-[0.95rem] font-bold tracking-tight text-foreground no-underline" href={homeHref}>
      <img src="/bub-logo.png" alt="Bub" width="32" height="32" class="h-8 w-8 dark:hidden" />
      <img src="/bub-logo-dark.png" alt="Bub" width="32" height="32" class="h-8 w-8 hidden dark:block" />
      <span>Bub</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-5 text-sm text-muted-foreground md:flex" role="navigation" aria-label="Main navigation">
      {navItems.map((item) => (
        <a
          class="flex items-center gap-1.5 no-underline transition-colors hover:text-foreground"
          href={item.href}
        >
          {item.icon && <Icon name={item.icon} size={14} class="opacity-50" aria-hidden="true" />}
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Right side -->
    <div class="flex items-center gap-2">
      <!-- GitHub star button (desktop) -->
      <a
        class="hidden items-center gap-1.5 border border-border px-3.5 py-1.5 text-sm text-foreground no-underline transition-colors hover:bg-secondary md:inline-flex"
        href="https://github.com/bubbuild/bub"
        target="_blank"
        rel="noreferrer"
      >
        <Icon name="github" size={14} class="opacity-50" aria-hidden="true" />
        <span>Star</span>
        <span class="border-l border-border pl-1.5 text-xs text-muted-foreground">{stars}</span>
      </a>
      <a
        class="hidden items-center gap-1.5 border border-border px-3.5 py-1.5 text-sm text-foreground no-underline transition-colors hover:bg-secondary md:inline-flex"
        href={languageHref}
      >
        <Icon name="globe" size={14} class="opacity-50" aria-hidden="true" />
        {languageLabel}
      </a>
      <ThemeToggle />

      <!-- Mobile menu -->
      <details class="group md:hidden">
        <summary class="inline-flex h-9 w-9 list-none items-center justify-center border border-border text-foreground marker:content-none" aria-label="Toggle navigation menu">
          <Icon name="menu" size={18} class="group-open:hidden" aria-hidden="true" />
          <Icon name="x" size={18} class="hidden group-open:block" aria-hidden="true" />
        </summary>
        <nav class="mobile-dropdown absolute left-0 right-0 top-full border-b border-border bg-background/95 backdrop-blur-sm p-5" role="navigation" aria-label="Mobile navigation">
          <div class="grid gap-0 text-sm">
            {navItems.map((item) => (
              <a
                class="flex items-center gap-2.5 border-b border-border/50 px-3 py-3 text-foreground no-underline transition-colors hover:bg-secondary"
                href={item.href}
              >
                <Icon name={item.icon} size={15} class="opacity-50" aria-hidden="true" />
                {item.label}
              </a>
            ))}
            <a class="flex items-center gap-2.5 border-b border-border/50 px-3 py-3 text-foreground no-underline transition-colors hover:bg-secondary" href="https://github.com/bubbuild/bub" target="_blank" rel="noreferrer">
              <Icon name="github" size={15} class="opacity-50" aria-hidden="true" />
              GitHub ★ {stars}
            </a>
            <a class="flex items-center gap-2.5 px-3 py-3 text-foreground no-underline transition-colors hover:bg-secondary" href={languageHref}>
              <Icon name="globe" size={15} class="opacity-50" aria-hidden="true" />
              {languageLabel}
            </a>
          </div>
        </nav>
      </details>
    </div>
  </div>
</header>

<style>
  .mobile-dropdown {
    animation: mobile-menu-slide-down 0.2s ease-out;
  }
  @keyframes mobile-menu-slide-down {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

---
interface Props {
  eyebrow?: string;
  heading?: string;
  description?: string[];
  hookStages?: { name: string; note: string }[];
}

const {
  eyebrow = 'Architecture',
  heading = 'Hooks define every turn stage.',
  description = [
    'Every stage in a Bub turn is a pluggy hook. The built-in implementation is just another plugin.',
    'Override any stage by registering your own. Later plugins take priority. No forking, no framework privilege.',
  ],
  hookStages = [
    { name: 'resolve_session', note: 'Route to the right conversation' },
    { name: 'load_state', note: 'Reconstruct context from tape' },
    { name: 'build_prompt', note: 'Assemble system + history + tools' },
    { name: 'run_model', note: 'Call the LLM provider' },
    { name: 'render_outbound', note: 'Format the reply for the channel' },
    { name: 'save_state', note: 'Persist to tape' },
    { name: 'dispatch_outbound', note: 'Send to CLI / Telegram / etc.' },
  ],
} = Astro.props;

// Parabolic arc heights (center tallest, edges shortest)
const heights = [120, 147, 173, 200, 173, 147, 120];
const opacities = [0.5, 0.67, 0.83, 1.0, 0.83, 0.67, 0.5];
---

<section class="relative overflow-hidden bg-secondary/30 py-20 md:py-28" data-reveal>
  <div class="relative mx-auto max-w-6xl px-5 md:px-8">
    <!-- Text block -->
    <div class="mx-auto mb-14 max-w-2xl text-center">
      <p class="mb-4 font-mono text-xs uppercase tracking-widest text-muted-foreground">
        {eyebrow}
      </p>
      <h2 class="text-[clamp(1.8rem,4vw,2.75rem)] font-extrabold leading-[1.1] tracking-tight text-foreground">
        {heading}
      </h2>
      <div class="mt-5 space-y-3">
        {description.map((p) => (
          <p class="text-[0.95rem] leading-relaxed text-muted-foreground">{p}</p>
        ))}
      </div>
    </div>

    <!-- Arc visualization -->
    <div class="flex items-end justify-center gap-2 md:gap-3" data-hook-stages>
      {hookStages.map((stage, i) => (
        <div
          class="hook-stage flex min-w-0 flex-1 flex-col border border-border bg-card p-3 transition-all duration-500 md:p-4"
          data-hook-stage={i}
          style={`height: ${heights[i]}px; opacity: ${opacities[i]};`}
        >
          <span class="mb-1.5 inline-flex h-5 w-5 shrink-0 items-center justify-center bg-secondary font-mono text-[0.6rem] font-bold text-muted-foreground transition-colors duration-500">
            {i + 1}
          </span>
          <span class="font-mono text-[0.65rem] font-medium leading-tight text-foreground md:text-[0.72rem]">
            {stage.name}()
          </span>
          <p class="hook-note mt-auto text-[0.58rem] leading-snug text-muted-foreground opacity-0 transition-all duration-500 md:text-[0.62rem]">
            {stage.note}
          </p>
        </div>
      ))}
    </div>

    <p class="mt-4 text-center font-mono text-[0.65rem] text-muted-foreground/60">
      process_inbound()
    </p>
  </div>
</section>

<style>
  .hook-stage.active {
    background-color: var(--primary);
    opacity: 1 !important;
    transform: scale(1.05);
    transform-origin: bottom center;
  }
  .hook-stage.active .hook-note {
    opacity: 1;
    color: var(--primary-foreground);
  }
  .hook-stage.active span:first-child {
    background-color: var(--primary-foreground);
    color: var(--primary);
  }
  .hook-stage.active span.font-mono {
    color: var(--primary-foreground);
  }
</style>

<script>
  import { inView } from 'motion';

  function initHookAnimation() {
    const container = document.querySelector('[data-hook-stages]');
    if (!container) return;

    const stages = container.querySelectorAll('[data-hook-stage]');
    if (!stages.length) return;

    let current = 0;
    let interval: ReturnType<typeof setInterval> | null = null;

    function cycle() {
      stages.forEach((s) => s.classList.remove('active'));
      stages[current]?.classList.add('active');
      current = (current + 1) % stages.length;
    }

    inView(container, () => {
      cycle();
      interval = setInterval(cycle, 2200);
      return () => {
        if (interval) clearInterval(interval);
        stages.forEach((s) => s.classList.remove('active'));
      };
    }, { margin: '-10% 0px' });
  }

  initHookAnimation();
  document.addEventListener('astro:page-load', initHookAnimation);
</script>

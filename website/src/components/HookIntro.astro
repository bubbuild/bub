---
interface Props {
  eyebrow?: string;
  heading?: string;
  description?: string[];
  hookStages?: { name: string; note: string }[];
}

const {
  eyebrow = 'Architecture',
  heading = 'Hooks define every turn stage.',
  description = [
    'Every stage in a Bub turn is a pluggy hook. The built-in implementation is just another plugin.',
    'Override any stage by registering your own. Later plugins take priority. No forking, no framework privilege.',
  ],
  hookStages = [
    { name: 'resolve_session', note: 'Route to the right conversation' },
    { name: 'load_state', note: 'Reconstruct context from tape' },
    { name: 'build_prompt', note: 'Assemble system + history + tools' },
    { name: 'run_model', note: 'Call the LLM provider' },
    { name: 'render_outbound', note: 'Format the reply for the channel' },
    { name: 'save_state', note: 'Persist to tape' },
    { name: 'dispatch_outbound', note: 'Send to CLI / Telegram / etc.' },
  ],
} = Astro.props;

// Bell-curve widths/opacities by distance from active stage
const WIDTHS   = ['100%', '84%', '66%', '50%', '38%'];
const OPACITIES = [1.0,    0.7,   0.45,  0.28,  0.16];

// SSR initial state: center stage active for a nice bell shape on load
const INIT_ACTIVE = 3;
const initStyle = hookStages.map((_, i) => {
  const d = Math.min(Math.abs(i - INIT_ACTIVE), WIDTHS.length - 1);
  return `width:${WIDTHS[d]};opacity:${OPACITIES[d]}`;
});
---

<section class="relative overflow-hidden bg-secondary/30 py-20 md:py-28" data-reveal aria-label="Hook architecture">
  <div class="relative mx-auto max-w-6xl px-5 md:px-8">
    <div class="flex flex-col gap-12 md:flex-row md:items-center md:gap-16 lg:gap-24">

      <!-- Left: intro text -->
      <div class="md:w-[42%] md:shrink-0">
        <p class="mb-4 font-mono text-xs uppercase tracking-widest text-muted-foreground">
          {eyebrow}
        </p>
        <h2 class="text-[clamp(1.8rem,4vw,2.75rem)] font-extrabold leading-[1.1] tracking-tight text-foreground">
          {heading}
        </h2>
        <div class="mt-5 space-y-3">
          {description.map((p) => (
            <p class="text-[0.95rem] leading-relaxed text-muted-foreground">{p}</p>
          ))}
        </div>
        <p class="mt-8 font-mono text-[0.65rem] text-muted-foreground/50">process_inbound()</p>
      </div>

      <!-- Right: vertical stage visualization (centered bars, fixed row height) -->
      <div class="flex flex-1 flex-col items-center gap-1.5 overflow-hidden" data-hook-stages>
        {hookStages.map((stage, i) => (
          <div class="flex h-11 w-full items-center justify-center">
            <div
              class="hook-stage flex h-full items-center overflow-hidden border border-border bg-card px-3 md:px-4"
              data-hook-stage={i}
              style={initStyle[i]}
            >
              <span class="stage-badge mr-3 inline-flex h-5 w-5 shrink-0 items-center justify-center bg-foreground font-mono text-[0.6rem] font-bold text-background">
                {i + 1}
              </span>
              <span class="stage-name whitespace-nowrap font-mono text-[0.65rem] font-medium leading-tight text-foreground md:text-[0.72rem]">
                {stage.name}()
              </span>
              <p class="hook-note ml-auto hidden whitespace-nowrap pl-3 text-right text-[0.58rem] leading-snug text-muted-foreground md:block md:text-[0.62rem]">
                {stage.note}
              </p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .hook-stage {
    will-change: width, opacity, transform;
    transition: background-color 0.35s ease, border-color 0.35s ease;
  }
  .hook-stage.active {
    background-color: var(--primary);
    border-color: var(--primary);
  }
  .hook-stage .stage-badge,
  .hook-stage .stage-name {
    transition: color 0.3s ease, background-color 0.3s ease;
  }
  .hook-stage.active .stage-badge {
    background-color: var(--primary-foreground);
    color: var(--primary);
  }
  .hook-stage.active .stage-name {
    color: var(--primary-foreground);
  }
  .hook-note {
    opacity: 0;
    transition: opacity 0.35s ease, color 0.35s ease;
  }
  .hook-stage.active .hook-note {
    opacity: 0.8;
    color: var(--primary-foreground);
  }
</style>

<script>
  import { animate, inView } from 'motion';

  const WIDTHS    = ['100%', '84%', '66%', '50%', '38%'];
  const OPACITIES = [1.0,    0.7,   0.45,  0.28,  0.16];

  function initHookAnimation() {
    const container = document.querySelector('[data-hook-stages]');
    if (!container) return;

    const stages = Array.from(
      container.querySelectorAll('[data-hook-stage]')
    ) as HTMLElement[];
    if (!stages.length) return;

    let current = 0;
    let interval: ReturnType<typeof setInterval> | null = null;

    function applyState(activeIdx: number) {
      stages.forEach((el, i) => {
        const dist = Math.min(Math.abs(i - activeIdx), WIDTHS.length - 1);
        const isActive = i === activeIdx;
        const delay = dist * 0.045;

        // Width + opacity with spring-like overshoot
        animate(el, { width: WIDTHS[dist], opacity: OPACITIES[dist] }, {
          type: 'spring',
          stiffness: 320,
          damping: 28,
          mass: 0.8,
          delay,
        });

        // Active bar gets a subtle pop scale
        if (isActive) {
          animate(el, { scale: [1, 1.025, 1] }, {
            duration: 0.5,
            ease: [0.22, 1, 0.36, 1],
          });
        }

        el.classList.toggle('active', isActive);
      });
    }

    function cycle() {
      applyState(current);
      current = (current + 1) % stages.length;
    }

    inView(container, () => {
      cycle();
      interval = setInterval(cycle, 2200);
      return () => {
        if (interval) clearInterval(interval);
        stages.forEach((el) => {
          el.classList.remove('active');
          el.style.transform = '';
        });
      };
    }, { margin: '-10% 0px' });
  }

  initHookAnimation();
  document.addEventListener('astro:page-load', initHookAnimation);
</script>

---
import Icon from './ui/Icon.astro';

const {
  copyright = `© ${new Date().getFullYear()} Bub Contributors`,
} = Astro.props;
---

<footer class="py-8" role="contentinfo">
  <div class="mx-auto max-w-6xl px-5 md:px-8">
    <div class="flex flex-col items-center gap-6 text-center md:flex-row md:justify-between md:gap-0 md:text-left">
      <a class="flex items-center gap-2 no-underline" href="/">
        <img src="/bub-logo.png" alt="Bub" width="24" height="24" class="h-6 w-6 dark:hidden" />
        <img src="/bub-logo-dark.png" alt="Bub" width="24" height="24" class="hidden h-6 w-6 dark:block" />
        <span class="text-sm font-semibold text-foreground">Bub</span>
      </a>

      <div class="flex flex-wrap items-center justify-center gap-5 text-sm text-muted-foreground md:justify-end">
        <a class="flex items-center gap-1.5 no-underline transition-colors hover:text-foreground" href="https://github.com/bubbuild/bub" target="_blank" rel="noreferrer">
          <Icon name="github" size={13} aria-hidden="true" />
          GitHub
        </a>
        <a class="flex items-center gap-1.5 no-underline transition-colors hover:text-foreground" href="https://github.com/bubbuild/bub/blob/main/LICENSE" target="_blank" rel="noreferrer">
          <Icon name="scale" size={13} aria-hidden="true" />
          Apache-2.0
        </a>
        <span>{copyright}</span>
      </div>
    </div>
  </div>
</footer>

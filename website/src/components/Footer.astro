---
import Icon from './ui/Icon.astro';

const {
  docsHref = '/en/getting-started/',
  docsLabel = 'Docs',
  githubHref = 'https://github.com/bubbuild/bub',
  githubLabel = 'GitHub',
  licenseHref = 'https://github.com/bubbuild/bub/blob/main/LICENSE',
  licenseLabel = 'Apache-2.0',
  copyright = `© ${new Date().getFullYear()} Bub Contributors`,
} = Astro.props;
---

<footer class="border-t border-border py-14">
  <div class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-6 px-5 sm:flex-row sm:items-center md:px-8">
    <div class="flex items-center gap-2.5">
      <img src="/bub-logo.png" alt="Bub" width="28" height="28" class="h-7 w-7" />
      <span class="text-sm font-bold tracking-tight text-foreground">Bub</span>
    </div>

    <nav class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-muted-foreground" aria-label="Footer navigation">
      <a class="no-underline transition-colors hover:text-foreground" href={docsHref}>
        <Icon name="book" size={13} class="mr-1 inline-flex opacity-50" />
        {docsLabel}
      </a>
      <a class="no-underline transition-colors hover:text-foreground" href={githubHref} target="_blank" rel="noreferrer">
        <Icon name="github" size={13} class="mr-1 inline-flex opacity-50" />
        {githubLabel}
      </a>
      <a class="no-underline transition-colors hover:text-foreground" href={licenseHref} target="_blank" rel="noreferrer">
        {licenseLabel}
      </a>
      <span class="text-xs text-muted-foreground/50">{copyright}</span>
    </nav>
  </div>
</footer>

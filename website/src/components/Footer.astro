---
import Icon from './ui/Icon.astro';

const {
  copyright = `© ${new Date().getFullYear()} Bub Contributors`,
} = Astro.props;
---

<footer class="border-t border-border py-8">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 md:px-8">
    <a class="flex items-center gap-2 no-underline" href="/">
      <img src="/bub-logo.png" alt="Bub" width="24" height="24" class="h-6 w-6" />
      <span class="text-sm font-semibold text-foreground">Bub</span>
    </a>

    <div class="flex items-center gap-5 text-sm text-muted-foreground">
      <a class="flex items-center gap-1.5 no-underline transition-colors hover:text-foreground" href="https://github.com/bubbuild/bub" target="_blank" rel="noreferrer">
        <Icon name="github" size={13} />
        GitHub
      </a>
      <a class="flex items-center gap-1.5 no-underline transition-colors hover:text-foreground" href="https://github.com/bubbuild/bub/blob/main/LICENSE" target="_blank" rel="noreferrer">
        <Icon name="scale" size={13} />
        Apache-2.0
      </a>
      <span>{copyright}</span>
    </div>
  </div>
</footer>

---
const {
  eyebrow = 'Quick start',
  heading = 'Up in three steps.',
  steps = [
    {
      number: '01',
      title: 'Install',
      code: 'pip install bub',
      lang: 'bash',
    },
    {
      number: '02',
      title: 'Configure',
      code: `cp env.example .env
# set BUB_MODEL and your provider key`,
      lang: 'bash',
    },
    {
      number: '03',
      title: 'Run',
      code: `uv run bub chat                      # interactive
uv run bub run "summarize this repo" # one-shot
uv run bub gateway                   # channel listener`,
      lang: 'bash',
    },
  ],
  primaryHref = '/en/getting-started/installation/',
  primaryLabel = 'Full installation guide',
} = Astro.props;
---

<section class="py-20 md:py-28">
  <div class="mx-auto max-w-[calc(var(--content-max)+var(--page-gutter)*2)] px-[var(--page-gutter)]">
    <div class="mb-12 max-w-xl">
      <p class="mb-4 font-['JetBrains_Mono'] text-xs uppercase tracking-[0.18em] text-[var(--accent)]">
        {eyebrow}
      </p>
      <h2 class="text-[clamp(1.9rem,4vw,3rem)] font-[780] leading-[1.05] tracking-[-0.04em] text-[var(--fg)]">
        {heading}
      </h2>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {
        steps.map((step) => (
          <div class="relative overflow-hidden rounded-[1.6rem] border border-[var(--line)] bg-[color:color-mix(in_oklab,var(--bg-elevated)_80%,transparent)] p-6">
            <div class="mb-5 flex items-center gap-3">
              <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[color:var(--accent-soft)] font-['JetBrains_Mono'] text-xs font-bold text-[var(--accent)]">
                {step.number}
              </span>
              <span class="text-[0.95rem] font-[700] tracking-[-0.02em] text-[var(--fg)]">{step.title}</span>
            </div>
            <pre class="overflow-x-auto rounded-[1.1rem] border border-[var(--line)] bg-[color:color-mix(in_oklab,var(--bg)_75%,black_25%)] p-4 font-['JetBrains_Mono'] text-[0.78rem] leading-6 text-[var(--fg)]"><code>{step.code}</code></pre>
          </div>
        ))
      }
    </div>

    <div class="mt-8">
      <a
        class="inline-flex min-h-[2.75rem] items-center gap-2 rounded-full border border-[var(--line)] bg-[color:color-mix(in_oklab,var(--bg-elevated)_88%,transparent)] px-[1.2rem] py-[0.7rem] text-sm font-bold text-[var(--fg)] no-underline transition-[border-color,transform] duration-150 hover:border-[color:color-mix(in_oklab,var(--accent)_38%,var(--line))] hover:-translate-y-px"
        href={primaryHref}
      >
        {primaryLabel}
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

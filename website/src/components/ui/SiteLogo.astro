---
import { Image } from 'astro:assets';
import logoDark from '@/assets/bub-logo-dark.png';
import logoLight from '@/assets/bub-logo.png';

interface Props {
  alt?: string;
  width: number;
  height: number;
  class?: string;
  loading?: 'eager' | 'lazy';
}

const {
  alt = 'Bub',
  width,
  height,
  class: className,
  loading = 'eager',
} = Astro.props;
---

<Image
  src={logoLight}
  alt={alt}
  width={width}
  height={height}
  loading={loading}
  densities={[2]}
  class:list={[className, 'dark:hidden']}
/>
<Image
  src={logoDark}
  alt={alt}
  width={width}
  height={height}
  loading={loading}
  densities={[2]}
  class:list={[className, 'hidden dark:block']}
/>

---
interface Props {
  eyebrow?: string;
  heading?: string;
  subheading?: string;
  descriptions?: string[];
  align?: 'left' | 'center';
  subheadingClass?: string;
  descriptionsClass?: string;
  class?: string;
}

const {
  eyebrow,
  heading,
  subheading,
  descriptions = [],
  align = 'left',
  subheadingClass,
  descriptionsClass,
  class: className,
}: Props = Astro.props;
---

<div class:list={[align === 'center' && 'mx-auto text-center', 'mb-12 max-w-2xl', className]}>
  {eyebrow && (
    <p class="mb-4 font-mono text-xs uppercase tracking-widest text-muted-foreground">
      {eyebrow}
    </p>
  )}
  {heading && (
    <h2 class="text-[clamp(1.8rem,4vw,2.75rem)] font-extrabold leading-[1.1] tracking-tight text-foreground">
      {heading}
    </h2>
  )}
  {subheading && (
    <p class:list={['mt-4 text-[0.95rem] leading-relaxed text-muted-foreground', subheadingClass]}>
      {subheading}
    </p>
  )}
  {descriptions.length > 0 && (
    <div class:list={['mt-4 space-y-3', descriptionsClass]}>
      {descriptions.map((text) => (
        <p class="text-[0.95rem] leading-relaxed text-muted-foreground">{text}</p>
      ))}
    </div>
  )}
</div>

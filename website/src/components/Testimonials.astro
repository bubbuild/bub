---
import Icon from './ui/Icon.astro';
import SectionHeading from './ui/SectionHeading.astro';

type TestimonialItem = {
  name: string;
  handle: string;
  text: string;
  avatar?: string;
  platform?: string;
};

interface Props {
  eyebrow?: string;
  heading?: string;
  testimonials?: TestimonialItem[];
}

const { eyebrow, heading, testimonials = [] } = Astro.props;

const col1 = testimonials.filter((_, i) => i % 3 === 0);
const col2 = testimonials.filter((_, i) => i % 3 === 1);
const col3 = testimonials.filter((_, i) => i % 3 === 2);

const colorAccents = [
  'border-l-chart-1',
  'border-l-chart-2',
  'border-l-chart-3',
  'border-l-chart-4',
  'border-l-chart-5',
  'border-l-chart-1',
];
---

<section class="relative py-20 md:py-28" data-reveal aria-label="Testimonials">
  <div class="relative mx-auto max-w-6xl px-5 md:px-8">
    <SectionHeading eyebrow={eyebrow} heading={heading} align="center" />

    <div class="testimonials-wrapper relative" data-testimonials>
      <div class="pointer-events-none absolute inset-x-0 top-0 z-10 h-20 bg-gradient-to-b from-background to-transparent" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 bottom-0 z-10 h-20 bg-gradient-to-t from-background to-transparent" aria-hidden="true"></div>

      <div class="testimonials-columns grid h-[320px] gap-3 overflow-hidden sm:h-[380px] sm:grid-cols-2 lg:h-[440px] lg:grid-cols-3">
        <!-- Column 1: scroll up -->
        <div class="testimonial-col testimonial-col-up min-w-0">
          <div class="flex flex-col gap-3">
            {[...col1, ...col1].map((t, i) => (
              <div class:list={['border border-border border-l-[3px] bg-card p-4', colorAccents[i % colorAccents.length]]}>
                <p class="text-[0.84rem] leading-relaxed text-foreground/85">{t.text}</p>
                <div class="mt-3 flex items-center gap-2.5">
                  {t.avatar ? (
                    <img src={t.avatar} alt={t.name} class="h-7 w-7 shrink-0 object-cover" loading="lazy" width="28" height="28" />
                  ) : (
                    <div class="flex h-7 w-7 shrink-0 items-center justify-center bg-secondary font-mono text-[0.6rem] font-bold text-foreground">
                      {t.name.charAt(0)}
                    </div>
                  )}
                  <div class="min-w-0 flex-1">
                    <p class="truncate text-xs font-bold text-foreground">{t.name}</p>
                    <p class="truncate text-[0.65rem] text-muted-foreground">{t.handle}</p>
                  </div>
                  {t.platform && <Icon name={t.platform} size={12} class="shrink-0 text-muted-foreground/50" aria-hidden="true" />}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Column 2: scroll down -->
        <div class="testimonial-col testimonial-col-down hidden sm:block">
          <div class="flex flex-col gap-3">
            {[...col2, ...col2].map((t, i) => (
              <div class:list={['border border-border border-l-[3px] bg-card p-4', colorAccents[(i + 2) % colorAccents.length]]}>
                <p class="text-[0.84rem] leading-relaxed text-foreground/85">{t.text}</p>
                <div class="mt-3 flex items-center gap-2.5">
                  {t.avatar ? (
                    <img src={t.avatar} alt={t.name} class="h-7 w-7 shrink-0 object-cover" loading="lazy" width="28" height="28" />
                  ) : (
                    <div class="flex h-7 w-7 shrink-0 items-center justify-center bg-secondary font-mono text-[0.6rem] font-bold text-foreground">
                      {t.name.charAt(0)}
                    </div>
                  )}
                  <div class="min-w-0 flex-1">
                    <p class="truncate text-xs font-bold text-foreground">{t.name}</p>
                    <p class="truncate text-[0.65rem] text-muted-foreground">{t.handle}</p>
                  </div>
                  {t.platform && <Icon name={t.platform} size={12} class="shrink-0 text-muted-foreground/50" aria-hidden="true" />}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Column 3: scroll up (slower) -->
        <div class="testimonial-col testimonial-col-up-slow hidden lg:block">
          <div class="flex flex-col gap-3">
            {[...col3, ...col3].map((t, i) => (
              <div class:list={['border border-border border-l-[3px] bg-card p-4', colorAccents[(i + 4) % colorAccents.length]]}>
                <p class="text-[0.84rem] leading-relaxed text-foreground/85">{t.text}</p>
                <div class="mt-3 flex items-center gap-2.5">
                  {t.avatar ? (
                    <img src={t.avatar} alt={t.name} class="h-7 w-7 shrink-0 object-cover" loading="lazy" width="28" height="28" />
                  ) : (
                    <div class="flex h-7 w-7 shrink-0 items-center justify-center bg-secondary font-mono text-[0.6rem] font-bold text-foreground">
                      {t.name.charAt(0)}
                    </div>
                  )}
                  <div class="min-w-0 flex-1">
                    <p class="truncate text-xs font-bold text-foreground">{t.name}</p>
                    <p class="truncate text-[0.65rem] text-muted-foreground">{t.handle}</p>
                  </div>
                  {t.platform && <Icon name={t.platform} size={12} class="shrink-0 text-muted-foreground/50" aria-hidden="true" />}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonial-col {
    overflow: hidden;
  }
  .testimonial-col > div {
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-play-state: paused;
  }
  .testimonial-col-up > div {
    animation-name: scroll-up;
    animation-duration: 45s;
  }
  .testimonial-col-down > div {
    animation-name: scroll-down;
    animation-duration: 40s;
  }
  .testimonial-col-up-slow > div {
    animation-name: scroll-up;
    animation-duration: 55s;
  }

  :global([data-testimonials-playing]) .testimonial-col > div {
    animation-play-state: running;
  }

  @keyframes scroll-up {
    from { transform: translateY(0); }
    to { transform: translateY(-50%); }
  }

  @keyframes scroll-down {
    from { transform: translateY(-50%); }
    to { transform: translateY(0); }
  }
</style>

<script>
  import { inView } from 'motion';

  function initTestimonialsViewport() {
    const wrapper = document.querySelector('[data-testimonials]') as HTMLElement | null;
    if (!wrapper) return;

    inView(wrapper, () => {
      wrapper.setAttribute('data-testimonials-playing', '');
      return () => {
        wrapper.removeAttribute('data-testimonials-playing');
      };
    }, { margin: '-5% 0px' });
  }

  initTestimonialsViewport();
  document.addEventListener('astro:page-load', initTestimonialsViewport);
</script>

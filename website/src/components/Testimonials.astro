---
import SectionHeading from './ui/SectionHeading.astro';
import TestimonialCard from './TestimonialCard.astro';

type TestimonialItem = {
  name: string;
  handle: string;
  text: string;
  avatar?: string;
  platform?: string;
};

interface Props {
  eyebrow?: string;
  heading?: string;
  testimonials?: TestimonialItem[];
}

const { eyebrow, heading, testimonials = [] } = Astro.props;

const col1 = testimonials.filter((_, i) => i % 3 === 0);
const col2 = testimonials.filter((_, i) => i % 3 === 1);
const col3 = testimonials.filter((_, i) => i % 3 === 2);

const colorAccents = [
  'border-l-chart-1',
  'border-l-chart-2',
  'border-l-chart-3',
  'border-l-chart-4',
  'border-l-chart-5',
  'border-l-chart-1',
];

const columns = [
  {
    items: col1,
    className: 'testimonial-col testimonial-col-up min-w-0',
    offset: 0,
  },
  {
    items: col2,
    className: 'testimonial-col testimonial-col-down hidden sm:block',
    offset: 2,
  },
  {
    items: col3,
    className: 'testimonial-col testimonial-col-up-slow hidden lg:block',
    offset: 4,
  },
];
---

<section class="relative py-20 md:py-28" data-reveal aria-label="Testimonials">
  <div class="relative mx-auto max-w-6xl px-5 md:px-8">
    <SectionHeading eyebrow={eyebrow} heading={heading} align="center" />

    <div class="testimonials-wrapper relative" data-testimonials>
      <div class="pointer-events-none absolute inset-x-0 top-0 z-10 h-20 bg-gradient-to-b from-background to-transparent" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 bottom-0 z-10 h-20 bg-gradient-to-t from-background to-transparent" aria-hidden="true"></div>

      <div class="testimonials-columns grid h-[320px] gap-3 overflow-hidden sm:h-[380px] sm:grid-cols-2 lg:h-[440px] lg:grid-cols-3">
        {columns.map((column) => (
          <div class={column.className}>
            <div class="flex flex-col gap-3">
              {[...column.items, ...column.items].map((testimonial, i) => (
                <TestimonialCard
                  testimonial={testimonial}
                  accentClass={colorAccents[(i + column.offset) % colorAccents.length]}
                />
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .testimonial-col {
    overflow: hidden;
  }
  .testimonial-col > div {
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-play-state: paused;
  }
  .testimonial-col-up > div {
    animation-name: scroll-up;
    animation-duration: 45s;
  }
  .testimonial-col-down > div {
    animation-name: scroll-down;
    animation-duration: 40s;
  }
  .testimonial-col-up-slow > div {
    animation-name: scroll-up;
    animation-duration: 55s;
  }

  :global([data-testimonials-playing]) .testimonial-col > div {
    animation-play-state: running;
  }

  @keyframes scroll-up {
    from { transform: translateY(0); }
    to { transform: translateY(-50%); }
  }

  @keyframes scroll-down {
    from { transform: translateY(-50%); }
    to { transform: translateY(0); }
  }
</style>

<script>
  import { inView } from 'motion';

  function initTestimonialsViewport() {
    const wrapper = document.querySelector('[data-testimonials]') as HTMLElement | null;
    if (!wrapper) return;

    inView(wrapper, () => {
      wrapper.setAttribute('data-testimonials-playing', '');
      return () => {
        wrapper.removeAttribute('data-testimonials-playing');
      };
    }, { margin: '-5% 0px' });
  }

  initTestimonialsViewport();
  document.addEventListener('astro:page-load', initTestimonialsViewport);
</script>

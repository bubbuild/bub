---
const {
  badge = 'Born in group chats',
  title = 'A common shape for agents that live alongside people.',
  description = 'Hook-first. Tape-driven context. Channel-agnostic. Built for the messy, shared conversations where agents have to work beside real humans instead of performing in a sandbox.',
  primaryHref = '/en/getting-started/installation/',
  primaryLabel = 'Get Started',
  secondaryHref = 'https://github.com/bubbuild/bub',
  secondaryLabel = 'View on GitHub',
  metrics = [
    { label: 'Core size', value: '~200 lines' },
    { label: 'Context model', value: 'Tape-driven' },
    { label: 'Channels', value: 'CLI + Telegram' },
  ],
  panelEyebrow = 'Turn pipeline',
  panelDescription = 'CSS-only staggered flow matching the core Bub runtime.',
  panelBadge = 'live shape',
  renderOutboundLabel = 'render_outbound',
  bottomNotes = [
    'Hooks stay replaceable, so the core never needs a special case to accommodate channels or providers.',
    'The same turn shape survives CLI, Telegram, and future adapters without changing the orchestration model.',
  ],
} = Astro.props;

const pipeline = [
  'resolve_session',
  'load_state',
  'build_prompt',
  'run_model',
  'render_outbound',
  'save_state',
  'dispatch_outbound',
];
---

<section class="hero-grid relative overflow-hidden pb-18 pt-12 md:pb-24 md:pt-18">
  <div class="mx-auto max-w-[calc(var(--content-max)+var(--page-gutter)*2)] px-[var(--page-gutter)]">
    <div class="grid items-start gap-12 lg:grid-cols-[minmax(0,1.12fr)_minmax(20rem,0.88fr)] lg:gap-8">
      <div class="max-w-3xl">
        <div class="hero-chip inline-flex items-center gap-2 rounded-full border border-[var(--line)] bg-[color:color-mix(in_oklab,var(--bg-elevated)_84%,transparent)] px-[0.9rem] py-[0.55rem] font-['JetBrains_Mono'] text-[0.75rem] uppercase tracking-[0.08em] text-[var(--muted)]">
          <span class="hero-chip-dot h-[0.55rem] w-[0.55rem] rounded-full bg-[var(--accent)]"></span>
          <span>{badge}</span>
        </div>
        <h1 class="mt-7 max-w-4xl text-[clamp(2.9rem,7vw,5.8rem)] font-[780] leading-[0.92] tracking-[-0.06em] text-[var(--fg)]">
          {title}
        </h1>
        <p class="mt-6 max-w-2xl text-[1.08rem] leading-8 text-[var(--muted)] md:text-[1.18rem]">
          {description}
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            class="inline-flex min-h-[2.9rem] items-center justify-center gap-[0.6rem] rounded-full bg-[linear-gradient(135deg,var(--accent),var(--accent-strong))] px-[1.2rem] py-[0.8rem] font-bold text-[oklch(0.18_0.02_175)] no-underline shadow-[0_20px_40px_color-mix(in_oklab,var(--accent)_22%,transparent)] transition-transform duration-150 hover:-translate-y-px focus-visible:-translate-y-px"
            href={primaryHref}
          >
            {primaryLabel}
            <span aria-hidden="true">↗</span>
          </a>
          <a
            class="inline-flex min-h-[2.9rem] items-center justify-center gap-[0.6rem] rounded-full border border-[var(--line)] bg-[color:color-mix(in_oklab,var(--bg-elevated)_88%,transparent)] px-[1.2rem] py-[0.8rem] font-bold text-[var(--fg)] no-underline transition-[border-color,transform] duration-150 hover:border-[color:color-mix(in_oklab,var(--accent)_38%,var(--line))] hover:-translate-y-px focus-visible:border-[color:color-mix(in_oklab,var(--accent)_38%,var(--line))] focus-visible:-translate-y-px"
            href={secondaryHref}
            target="_blank"
            rel="noreferrer"
          >
            {secondaryLabel}
          </a>
        </div>
        <dl class="mt-10 grid max-w-2xl gap-4 sm:grid-cols-3">
          {metrics.map((metric) => (
            <div class="rounded-[1.35rem] border border-[var(--line)] bg-[color:color-mix(in_oklab,var(--bg-elevated)_80%,transparent)] p-4">
              <dt class="font-['JetBrains_Mono'] text-xs uppercase tracking-[0.18em] text-[var(--muted)]">{metric.label}</dt>
              <dd class="mt-3 text-2xl font-[800] tracking-[-0.05em] text-[var(--fg)]">{metric.value}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="relative">
        <div class="absolute inset-x-[12%] top-10 h-52 rounded-full bg-[color:color-mix(in_oklab,var(--accent)_24%,transparent)] blur-3xl"></div>
        <div class="relative overflow-hidden rounded-[2rem] border border-[var(--line)] bg-[linear-gradient(180deg,color-mix(in_oklab,var(--bg-elevated)_88%,transparent),color-mix(in_oklab,var(--bg)_92%,black_8%))] p-5 shadow-[var(--shadow)] md:p-6">
          <div class="flex items-center justify-between gap-4 border-b border-[var(--line)] pb-4">
            <div>
              <p class="font-['JetBrains_Mono'] text-xs uppercase tracking-[0.22em] text-[var(--muted)]">{panelEyebrow}</p>
              <p class="mt-2 text-sm text-[var(--muted)]">{panelDescription}</p>
            </div>
            <span class="rounded-full border border-[var(--line)] px-3 py-1 font-['JetBrains_Mono'] text-[0.68rem] uppercase tracking-[0.2em] text-[var(--accent)]">
              {panelBadge}
            </span>
          </div>
          <div class="mt-6 rounded-[1.5rem] border border-[var(--line)] bg-[color:color-mix(in_oklab,var(--bg)_75%,black_25%)] p-4 font-['JetBrains_Mono'] text-[0.82rem] leading-7 text-[var(--fg)] md:p-5">
            <div class="flex flex-wrap items-center gap-x-3 gap-y-2">
              {pipeline.slice(0, 4).map((step, index) => (
                <>
                  <span class="pipeline-node rounded-full border border-[var(--line)] bg-[color:var(--bg-elevated)] px-3 py-1" style={`--delay:${index * 120}ms`}>
                    {step}
                  </span>
                  {index < 3 && (
                    <span class="pipeline-arrow" aria-hidden="true" style={`--delay:${index * 120 + 80}ms`}>
                      →
                    </span>
                  )}
                </>
              ))}
            </div>
            <div class="ml-auto mt-5 flex w-fit items-center gap-3">
              <span class="pipeline-arrow text-xl" aria-hidden="true" style="--delay:560ms">↓</span>
              <span class="rounded-full border border-[var(--line)] bg-[color:var(--accent-soft)] px-3 py-1 text-[var(--accent)]">{renderOutboundLabel}</span>
            </div>
            <div class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-2 md:justify-end">
              {pipeline.slice(5).reverse().map((step, index) => (
                <>
                  <span class="pipeline-node rounded-full border border-[var(--line)] bg-[color:var(--bg-elevated)] px-3 py-1" style={`--delay:${760 + index * 120}ms`}>
                    {step}
                  </span>
                  {index < 1 && (
                    <span class="pipeline-arrow" aria-hidden="true" style={`--delay:${840 + index * 120}ms`}>
                      ←
                    </span>
                  )}
                </>
              ))}
            </div>
          </div>
          <div class="mt-5 grid gap-3 text-sm text-[var(--muted)] sm:grid-cols-2">
            {bottomNotes.map((note) => (
              <div class="rounded-[1.35rem] border border-[var(--line)] bg-[color:color-mix(in_oklab,var(--bg-elevated)_72%,transparent)] p-4">
                {note}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-grid::before {
    background-image:
      linear-gradient(to right, color-mix(in oklab, var(--line) 88%, transparent) 1px, transparent 1px),
      linear-gradient(to bottom, color-mix(in oklab, var(--line) 88%, transparent) 1px, transparent 1px);
    background-position: center;
    background-size: 22px 22px;
    content: '';
    inset: 0;
    mask-image: radial-gradient(circle at center, black 45%, transparent 88%);
    opacity: 0.28;
    pointer-events: none;
    position: absolute;
  }

  .pipeline-node {
    animation: fade-up 700ms cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: var(--delay, 0ms);
  }

  .pipeline-arrow {
    animation: pulse-line 1.8s ease-in-out infinite;
    animation-delay: var(--delay, 0ms);
    color: color-mix(in oklab, var(--accent) 76%, var(--fg));
  }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(18px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes pulse-line {
    0%,
    100% {
      opacity: 0.35;
    }

    50% {
      opacity: 1;
    }
  }
</style>

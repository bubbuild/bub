---
import { Code } from 'astro-expressive-code/components';
import Icon from './ui/Icon.astro';

const {
  badge = 'Hook-first · Tape-driven · Channel-agnostic',
  title = 'Bub is a tiny runtime for agents that live alongside people.',
  description = '~200 lines of core code. Hooks reshape every turn stage. Tapes record every decision. Channels adapt to any surface — CLI, Telegram, or your own.',
  primaryHref = '/en/getting-started/installation/',
  primaryLabel = 'Get Started',
  secondaryHref = 'https://github.com/bubbuild/bub',
  secondaryLabel = 'View on GitHub',
} = Astro.props;

const terminalCode = `$ pip install bub
$ echo 'BUB_MODEL=openai/gpt-4.1' > .env
$ bub chat
🤖 Bub is ready. Type a message…

> summarize this repo
  ✓ resolve_session
  ✓ load_state (tape: 0 entries)
  ✓ build_prompt (system + tools)
  ✓ run_model → gpt-4.1
  ✓ render_outbound
  ✓ save_state (tape: +3 entries)`;
---

<section class="hero-section relative overflow-hidden pb-20 pt-14 md:pb-28 md:pt-20">
  <!-- Dot grid bg -->
  <div class="dot-grid pointer-events-none absolute inset-0 text-foreground/[0.04]" aria-hidden="true"></div>
  <!-- Glow -->
  <div class="pointer-events-none absolute left-1/2 top-0 -translate-x-1/2" aria-hidden="true">
    <div class="h-[500px] w-[800px] rounded-full bg-accent/10 blur-[120px]"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-5 md:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:gap-10">
      <!-- Left: text -->
      <div class="max-w-2xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 rounded-full border border-border bg-secondary/60 px-3.5 py-1.5 font-mono text-[0.7rem] uppercase tracking-widest text-muted-foreground">
          <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
          {badge}
        </div>

        <!-- Logo + heading -->
        <div class="mt-8 flex items-start gap-4">
          <img src="/bub-logo.png" alt="" width="56" height="56" class="hidden h-14 w-14 shrink-0 sm:block" aria-hidden="true" />
          <h1 class="text-[clamp(2.2rem,5.5vw,3.8rem)] font-extrabold leading-[1.05] tracking-tight text-foreground">
            <span class="bg-gradient-to-r from-accent via-primary to-accent bg-clip-text text-transparent">Bub</span>{' '}
            {title.replace(/^Bub\s*/, '')}
          </h1>
        </div>

        <p class="mt-6 max-w-xl text-[1.05rem] leading-7 text-muted-foreground">
          {description}
        </p>

        <!-- CTAs -->
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            class="inline-flex items-center justify-center gap-2 rounded-full bg-accent px-6 py-3 text-sm font-bold text-accent-foreground no-underline shadow-lg shadow-accent/20 transition-transform hover:-translate-y-0.5"
            href={primaryHref}
          >
            {primaryLabel}
            <Icon name="arrowUpRight" size={15} />
          </a>
          <a
            class="inline-flex items-center justify-center gap-2 rounded-full border border-border px-6 py-3 text-sm font-bold text-foreground no-underline transition-colors hover:bg-secondary"
            href={secondaryHref}
            target="_blank"
            rel="noreferrer"
          >
            <Icon name="github" size={15} />
            {secondaryLabel}
          </a>
        </div>
      </div>

      <!-- Right: terminal -->
      <div class="relative">
        <div class="pointer-events-none absolute inset-x-[10%] top-8 h-48 rounded-full bg-accent/15 blur-3xl" aria-hidden="true"></div>
        <div class="hero-terminal relative overflow-hidden rounded-2xl border border-border shadow-2xl shadow-black/10">
          <Code code={terminalCode} lang="ansi" frame="terminal" title="bub" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-terminal :global(.expressive-code) {
    margin: 0;
  }
  .hero-terminal :global(.expressive-code .frame) {
    border: none;
    border-radius: 0;
    box-shadow: none;
  }
  .hero-terminal :global(.expressive-code pre) {
    font-family: 'JetBrains Mono Variable', ui-monospace, monospace;
    font-size: 0.78rem;
    line-height: 1.7;
  }
</style>

---
import Icon from './ui/Icon.astro';

interface Props {
  contributors?: { initial: string; bg: string; avatar?: string; name?: string }[];
  label?: string;
}

const {
  contributors = [
    { initial: 'A', bg: '#3b82f6' },
    { initial: 'J', bg: '#10b981' },
    { initial: 'S', bg: '#f59e0b' },
    { initial: 'M', bg: '#8b5cf6' },
    { initial: 'K', bg: '#ef4444' },
    { initial: 'A', bg: '#3b82f6' },
    { initial: 'J', bg: '#10b981' },
    { initial: 'S', bg: '#f59e0b' },
    { initial: 'M', bg: '#8b5cf6' },
    { initial: 'K', bg: '#ef4444' },
  ],
  label = 'Developed by contributors worldwide',
} = Astro.props;
---

<div class="flex items-center gap-3">
  <div class="flex -space-x-3">
    {contributors.map((c, i) => (
      <div
        class:list={[
          'group relative h-7 w-7 md:h-8 md:w-8',
          i >= 5 ? 'hidden md:block' : '',
        ]}
      >
        <div
          class="absolute inset-0 flex items-center justify-center overflow-hidden rounded-full border-2 border-background text-xs font-bold text-white transition-transform duration-200 ease-out group-hover:-translate-y-2 group-hover:scale-110 group-hover:z-10"
          style={`background-color: ${c.bg};`}
          title={c.name}
        >
          {c.avatar ? (
            <img
              src={c.avatar}
              alt={c.name ?? c.initial}
              class="h-full w-full object-cover"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
            />
          ) : null}
          <span
            class="absolute inset-0 flex items-center justify-center"
            style={c.avatar ? 'display:none;' : ''}
          >
            {c.initial}
          </span>
        </div>
      </div>
    ))}
    <!-- Ellipsis avatar -->
    <div
      class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-background bg-secondary text-muted-foreground md:h-8 md:w-8"
      title="and many more"
      aria-label="and many more contributors"
    >
      <Icon name="ellipsis" size={14} aria-hidden="true" />
    </div>
  </div>
  <span class="text-xs text-muted-foreground">{label}</span>
</div>


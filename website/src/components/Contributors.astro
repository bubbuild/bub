---
import Icon from './ui/Icon.astro';
import type { GitHubContributor } from '../lib/github';

interface Props {
  contributors?: GitHubContributor[];
  label?: string;
}

const {
  contributors = [],
  label = 'Developed by contributors worldwide',
} = Astro.props;
---

<div class="flex items-center gap-3">
  <div class="flex -space-x-3">
    {contributors.map((c, i) => (
      <div
        class:list={[
          'group relative h-7 w-7 md:h-8 md:w-8',
          i >= 5 ? 'hidden md:block' : '',
        ]}
      >
        <a
          href={c.html_url}
          target="_blank"
          rel="noreferrer"
          class="absolute inset-0 flex items-center justify-center overflow-hidden rounded-full border-2 border-background transition-transform duration-200 ease-out group-hover:-translate-y-2 group-hover:scale-110 group-hover:z-10"
          title={c.login}
        >
          <img
            src={c.avatar_url}
            alt={c.login}
            class="h-full w-full object-cover"
          />
        </a>
      </div>
    ))}
    <!-- Ellipsis avatar -->
    <div
      class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-background bg-secondary text-muted-foreground md:h-8 md:w-8"
      title="and many more"
      aria-label="and many more contributors"
    >
      <Icon name="ellipsis" size={14} aria-hidden="true" />
    </div>
  </div>
  <span class="text-xs text-muted-foreground">{label}</span>
</div>


---
import Icon from './ui/Icon.astro';

interface Props {
  contributors?: { initial: string; bg: string }[];
  label?: string;
}

const {
  contributors = [
    { initial: 'A', bg: '#3b82f6' },
    { initial: 'J', bg: '#10b981' },
    { initial: 'S', bg: '#f59e0b' },
    { initial: 'M', bg: '#8b5cf6' },
    { initial: 'K', bg: '#ef4444' },
    { initial: 'A', bg: '#3b82f6' },
    { initial: 'J', bg: '#10b981' },
    { initial: 'S', bg: '#f59e0b' },
    { initial: 'M', bg: '#8b5cf6' },
    { initial: 'K', bg: '#ef4444' },
  ],
  label = 'Developed by contributors worldwide',
} = Astro.props;
---

<div class="flex items-center gap-3">
  <div class="flex -space-x-3">
    {contributors.map((c, i) => (
      <div
        class:list={[
          'flex h-7 w-7 items-center justify-center rounded-full border-2 border-background text-xs font-bold text-white md:h-8 md:w-8',
          i >= 5 ? 'hidden md:flex' : '',
        ]}
        style={`background-color: ${c.bg};`}
      >
        {c.initial}
      </div>
    ))}
    <!-- Ellipsis avatar -->
    <div
      class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-background bg-secondary text-muted-foreground md:h-8 md:w-8"
      title="and many more"
      aria-label="and many more contributors"
    >
      <Icon name="ellipsis" size={14} />
    </div>
  </div>
  <span class="text-xs text-muted-foreground">{label}</span>
</div>

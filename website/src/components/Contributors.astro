---
interface Props {
  contributors?: { initial: string; bg: string }[];
  label?: string;
}

const {
  contributors = [
    { initial: 'A', bg: '#3b82f6' },
    { initial: 'J', bg: '#10b981' },
    { initial: 'S', bg: '#f59e0b' },
    { initial: 'M', bg: '#8b5cf6' },
    { initial: 'K', bg: '#ef4444' },
  ],
  label = 'Trusted by contributors worldwide',
} = Astro.props;
---

<div class="flex items-center gap-3">
  <div class="flex -space-x-2">
    {contributors.map((c) => (
      <div
        class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-background text-xs font-bold text-white"
        style={`background-color: ${c.bg};`}
      >
        {c.initial}
      </div>
    ))}
  </div>
  <span class="text-xs text-muted-foreground">{label}</span>
</div>

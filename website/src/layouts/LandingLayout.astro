---
import Features from '@/components/Features.astro';
import Hero from '@/components/Hero.astro';
import HookIntro from '@/components/HookIntro.astro';
import TapeModel from '@/components/TapeModel.astro';
import Testimonials from '@/components/Testimonials.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getRepoStats } from '@/lib/github';
import { SITE_URL } from 'astro:env/client';

const { title, description, ogImage, hero, features = {}, hookIntro = {}, tapeModel = {}, testimonials = {} } = Astro.props;

const { contributors } = await getRepoStats();
---

<BaseLayout title={title} description={description} ogImage={ogImage} canonicalUrl={SITE_URL} bodyClass="ambient-page min-h-screen antialiased font-sans">
  <main id="main-content" class="relative isolate">
    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
      <svg class="grain-texture absolute inset-0 h-full w-full" xmlns="http://www.w3.org/2000/svg">
        <filter id="bub-grain">
          <feTurbulence type="fractalNoise" baseFrequency="0.7" numOctaves="3" stitchTiles="stitch" />
          <feColorMatrix type="saturate" values="0" />
        </filter>
        <rect width="100%" height="100%" filter="url(#bub-grain)" />
      </svg>
    </div>
    <div class="divide-y divide-border">
      <Hero {...hero} contributors={contributors} />
      <Features {...features} />
      <HookIntro {...hookIntro} />
      <TapeModel {...tapeModel} />
      <Testimonials {...testimonials} />
    </div>
  </main>
</BaseLayout>

<style>
  :global(body.ambient-page) {
    --ambient-gradient:
      radial-gradient(ellipse 60% 50% at 12% 8%, var(--site-ambient-1), transparent),
      radial-gradient(ellipse 50% 45% at 88% 42%, var(--site-ambient-2), transparent),
      radial-gradient(ellipse 55% 50% at 32% 85%, var(--site-ambient-3), transparent);
    background: var(--ambient-gradient), var(--background);
    background-attachment: fixed;
  }

  :global(body.ambient-page > header) {
    background-color: color-mix(in oklch, var(--background) 82%, transparent);
    background-image: var(--ambient-gradient);
    background-attachment: fixed;
    backdrop-filter: blur(12px) saturate(1.2);
  }

  :global(body.ambient-page > header .mobile-dropdown) {
    background-color: color-mix(in oklch, var(--background) 96%, transparent);
    background-image: var(--ambient-gradient);
    background-attachment: fixed;
    backdrop-filter: blur(20px) saturate(1.2);
  }

  :global(body.ambient-page > footer) {
    background-color: color-mix(in oklch, var(--background) 55%, transparent);
    background-image: var(--ambient-gradient);
    background-attachment: fixed;
    backdrop-filter: blur(8px);
  }

  .grain-texture {
    opacity: 0.04;
  }
  :global(.dark) .grain-texture,
  :global([data-theme="dark"]) .grain-texture {
    opacity: 0.06;
  }
</style>

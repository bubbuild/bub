import { useTranslations } from '../i18n/utils';
import { getLandingPageCopy } from '../i18n/landing-page';

const t = useTranslations('en');
const copy = getLandingPageCopy('en');
---

<LandingLayout
  title={t('site.title')}
  description={t('site.description')}
  hero={copy.hero}
/>

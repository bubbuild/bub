---
import Icon from '@/components/ui/Icon.astro';
import LinkButton from '@/components/ui/LinkButton.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getDocsHref, getLangFromUrl, useTranslations, useTranslatedPath } from '@/i18n/utils';

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);
const tp = useTranslatedPath(locale);
---

<BaseLayout title={`404 | Bub`} description={t('404.description')} robots="noindex" backToTop={false}>
  <main id="main-content" class="flex min-h-[calc(100vh-8rem)] items-center px-5 py-20 md:px-8">
    <div class="mx-auto w-full max-w-6xl">
      <p class="font-mono text-sm text-muted-foreground">404</p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-foreground md:text-5xl">
        {t('404.title')}
      </h1>
      <p class="mt-4 text-base text-muted-foreground max-w-sm">
        {t('404.description')}
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <LinkButton href={tp('/')} class="w-full px-6 py-3 sm:w-auto">
          <Icon name="arrowLeft" size={15} aria-hidden="true" />
          {t('404.home')}
        </LinkButton>
        <LinkButton
          href={getDocsHref(locale)}
          variant="secondary"
          class="w-full px-6 py-3 sm:w-auto"
        >
          <Icon name="book" size={15} aria-hidden="true" />
          {t('404.docs')}
        </LinkButton>
      </div>
    </div>
  </main>
</BaseLayout>

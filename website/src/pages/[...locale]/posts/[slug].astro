---
import { getCollection, render } from 'astro:content';
import { getLocales, getLocaleRouteParam, getPostSlug } from '@/i18n/utils';
import PostLayout from '@/layouts/PostLayout.astro';
import type { Locale } from '@/i18n/ui';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  return getLocales().flatMap((locale) => {
    const localePosts = allPosts.filter((post) => post.data.locale === locale);
    return localePosts.map((post) => ({
      params: {
        locale: getLocaleRouteParam(locale as Locale),
        slug: getPostSlug(post.id, locale as Locale),
      },
      props: { post },
    }));
  });
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  locale={post.data.locale}
  tags={post.data.tags ?? []}
  postId={post.id.replace(/\.md$/, '')}
>
  <Content />
</PostLayout>

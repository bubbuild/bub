---
export const prerender = false;

import { getCollection } from 'astro:content';
import LandingLayout from '../../layouts/LandingLayout.astro';
import { useTranslations } from '../../i18n/utils';
import { getLandingPageData, type LandingLocale } from '../../data/landing-page';
import { languages, defaultLang, type Locale } from '../../i18n/ui';

// In SSR mode, read locale from the catch-all param.
// `/`       → locale = undefined → defaultLang ('en')
// `/zh-cn/` → locale = 'zh-cn'
const { locale: localeParam } = Astro.params;
const locale = (localeParam ?? defaultLang) as Locale;

// Guard against catch-all hits from unknown paths (e.g. /foo/).
if (!(locale in languages)) {
  return Astro.redirect('/404');
}

const t = useTranslations(locale);
const pageData = getLandingPageData(locale as LandingLocale);

// Load testimonial items from the userwall content collection.
const userwallEntries = await getCollection('userwall');
const testimonials = {
  ...pageData.testimonials,
  testimonials: userwallEntries.map((entry) => entry.data),
};
---

<LandingLayout
  title={t('site.title')}
  description={t('site.description')}
  hero={pageData.hero}
  features={pageData.features}
  hookIntro={pageData.hookIntro}
  tapeModel={pageData.tapeModel}
  testimonials={testimonials}
/>

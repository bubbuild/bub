---
import LandingLayout from '../../layouts/LandingLayout.astro';
import { useTranslations } from '../../i18n/utils';
import { getLandingPageCopy } from '../../i18n/landing-page';
import { languages, defaultLang, type Locale } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { locale: lang === defaultLang ? undefined : lang },
    props: { locale: lang as Locale },
  }));
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const copy = getLandingPageCopy(locale);
---

<LandingLayout
  title={t('site.title')}
  description={t('site.description')}
  hero={copy.hero}
  features={copy.features}
  hookIntro={copy.hookIntro}
  tapeModel={copy.tapeModel}
  testimonials={copy.testimonials}
/>

---
export const prerender = false;

import { getCollection } from 'astro:content';
import { getLandingPageData } from '@/data/landing-page';
import { getLocaleFromParam, useTranslations } from '@/i18n/utils';
import { gitHubAvatarUrl } from '@/lib/github';
import LandingLayout from '@/layouts/LandingLayout.astro';

// In SSR mode, read locale from the catch-all param.
// `/`       → locale = undefined → defaultLang ('en')
// `/zh-cn/` → locale = 'zh-cn'
const { locale: localeParam } = Astro.params;
const locale = getLocaleFromParam(localeParam);

// Guard against catch-all hits from unknown paths (e.g. /foo/).
if (!locale) {
  return Astro.redirect('/404');
}

const t = useTranslations(locale);
const pageData = getLandingPageData(locale);
const ogImage = locale === 'en' ? '/og/index.png' : `/og/${locale}/index.png`;

// Load testimonial items from the userwall content collection.
const userwallEntries = await getCollection('userwall');
const testimonials = {
  ...pageData.testimonials,
  testimonials: userwallEntries.map((entry) => ({
    ...entry.data,
    avatar: gitHubAvatarUrl(entry.data.github),
  })),
};
---

<LandingLayout
  title={t('site.title')}
  description={t('site.description')}
  ogImage={ogImage}
  hero={pageData.hero}
  features={pageData.features}
  hookIntro={pageData.hookIntro}
  tapeModel={pageData.tapeModel}
  testimonials={testimonials}
/>

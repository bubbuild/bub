---
import '../../styles/global.css';
import Hero from '../../components/Hero.astro';
import NavBar from '../../components/NavBar.astro';
import Features from '../../components/Features.astro';
import HookIntro from '../../components/HookIntro.astro';
import TapeModel from '../../components/TapeModel.astro';
import Testimonials from '../../components/Testimonials.astro';
import Footer from '../../components/Footer.astro';
import { getLandingPageCopy } from '../../i18n/landing-page';

const { htmlLang, title, description, nav, hero, features, footer } = getLandingPageCopy('zh-cn');
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script is:inline>
      (() => {
        const storedTheme = localStorage.getItem('bub-theme');
        const preferredTheme =
          storedTheme || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.dataset.theme = preferredTheme;
      })();
    </script>
  </head>
  <body class="min-h-screen antialiased">
    <NavBar {...nav} />
    <main>
      <Hero {...hero} />
      <Features {...features} />
      <HookIntro />
      <TapeModel />
      <Testimonials />
    </main>
    <Footer {...footer} />
    <script is:inline>
      function setTheme(theme) {
        document.documentElement.dataset.theme = theme;
        localStorage.setItem('bub-theme', theme);
      }

      function toggleTheme() {
        const current = document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
        setTheme(current === 'light' ? 'dark' : 'light');
      }

      document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
        button.addEventListener('click', toggleTheme);
      });
    </script>

    <script>
      import { inView } from 'motion';
      document.querySelectorAll('[data-reveal]').forEach((el) => {
        Object.assign(el.style, { opacity: '0', transform: 'translateY(24px)', transition: 'opacity 0.7s ease, transform 0.7s ease' });
        inView(el, () => { Object.assign(el.style, { opacity: '1', transform: 'translateY(0)' }); }, { margin: '-8% 0px' });
      });
    </script>
  </body>
</html>
